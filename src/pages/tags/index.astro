---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');
const allTags = allPosts
  .filter(p => !p.data.draft)
  .flatMap(p => p.data.tags ?? []);

// Count posts per tag, sorted by count descending
const tagCounts = allTags.reduce((acc, tag) => {
  acc.set(tag, (acc.get(tag) || 0) + 1);
  return acc;
}, new Map<string, number>());

const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="Tags - Sebastian Aburto"
  description="Browse all blog posts by topic: Java, testing, Maven, Git, and more"
>
  <h1>Browse by topic</h1>
  <p class="tag-intro">All {sortedTags.length} tags across the blog:</p>
  <div class="tags-container">
    {sortedTags.map(([tag, count]) => (
      <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="tag-badge">
        {tag} <span class="tag-count">{count}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .tag-intro {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--text);
    font-size: 0.85rem;
    transition: background 0.15s, border-color 0.15s;
  }
  .tag-badge:hover {
    background: var(--code-bg);
    border-color: var(--link);
  }
  .tag-count {
    color: var(--muted);
    font-size: 0.75rem;
  }
</style>
