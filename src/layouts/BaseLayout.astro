---
import { execSync } from 'node:child_process';
import '../styles/global.css';
import saburtoAvatar from '../assets/saburto.webp';

let gitSha = '';
try {
  gitSha = execSync('git rev-parse --short HEAD', { encoding: 'utf-8' }).trim();
} catch {
  // not a git repo or git not available
}

export interface Props {
  title: string;
  description?: string;
  ogType?: string;
  ogImage?: string;
  articleDate?: string;
}

const SITE = 'https://saburto.com';
const { title, description, ogType, ogImage, articleDate } = Astro.props;
const pageUrl = new URL(Astro.url.pathname, SITE).href;
---

<!doctype html>
<html lang="en" class="light" data-theme="auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={pageUrl} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:type" content={ogType || 'website'} />
    <meta property="og:url" content={pageUrl} />
    {description && <meta property="og:description" content={description} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {articleDate && <meta property="article:published_time" content={articleDate} />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Mona+Sans:wght@400;600;700&family=Open+Sans:ital,wght@0,400;0,600;0,700;1,400&family=Fira+Code:wght@400&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LM76HVKGTY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LM76HVKGTY', {
        anonymize_ip: true,
        client_storage: 'none',
        allow_google_signals: false,
        allow_ad_personalization_signals: false
      });
    </script>
    <script is:inline>
      // Apply saved theme before paint to prevent flash
      (function() {
        const saved = localStorage.getItem('theme') || 'auto';
        const html = document.documentElement;
        html.setAttribute('data-theme', saved);
        const isDark = saved === 'dark' || (saved === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        html.className = isDark ? 'dark' : 'light';
      })();
    </script>
  </head>
  <body>
    <div class="container">
      <header class="site-header">
        <a href="/">
          <div class="site-name">Sebastian Aburto</div>
          <p class="subtitle">Thoughts, ideas, philosophy, and practical tips about software development</p>
        </a>
        <nav class="site-nav">
          <a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>blog</a>
          <a href="/tags/" class={Astro.url.pathname.startsWith('/tags') ? 'active' : ''}>tags</a>
          <a href="/projects">projects</a>
          <a href="/about">about</a>
          <div class="theme-toggle">
            <label for="theme-select" class="theme-label">
              <svg class="t-icon t-icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
              <svg class="t-icon t-icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              <svg class="t-icon t-icon-auto" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2"/><path d="M12 21v2"/><path d="M4.22 4.22l1.42 1.42"/><path d="M18.36 18.36l1.42 1.42"/><path d="M1 12h2"/><path d="M21 12h2"/><path d="M4.22 19.78l1.42-1.42"/><path d="M18.36 5.64l1.42-1.42"/><line x1="12" y1="5" x2="12" y2="10" stroke-dasharray="2 2"/></svg>
            </label>
            <select id="theme-select" class="theme-select" aria-label="Color scheme">
              <option value="auto">Auto</option>
              <option value="light">Light</option>
              <option value="dark">Dark</option>
            </select>
          </div>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-about">
          <img src={saburtoAvatar.src} alt="Sebastian Aburto" width="48" height="48" class="footer-avatar" loading="lazy" />
          <div>
            <p class="footer-name">Sebastian Aburto</p>
            <p>Seasoned Software Engineer, passionate about software development and a lifelong learner.</p>
          </div>
        </div>
        <div class="footer-social">
          <a href="https://github.com/saburto" target="_blank" rel="me noopener" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/saburto/" target="_blank" rel="me noopener" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="/rss.xml" aria-label="RSS Feed">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93z"/></svg>
          </a>
        </div>
        <p class="footer-ai"><a href="/ai-transparency">AI transparency</a></p>
        <p class="footer-disclaimer">All opinions are my own and not those of any employer or organization.</p>
        {gitSha && <p>Release {gitSha}, {new Date().toISOString().split('T')[0]}</p>}
        <p>&copy; {new Date().getFullYear()} Sebastian Aburto</p>
      </footer>
    </div>

    <script is:inline>
      (function() {
        const sel = document.getElementById('theme-select');
        const html = document.documentElement;

        function getCurrent() {
          return html.getAttribute('data-theme') || 'auto';
        }

        function apply(theme) {
          html.setAttribute('data-theme', theme);
          const isDark = theme === 'dark' || (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          html.className = isDark ? 'dark' : 'light';
          localStorage.setItem('theme', theme);
          sel.value = theme;
        }

        // Init
        apply(getCurrent());

        sel.addEventListener('change', () => {
          apply(sel.value);
        });
      })();
    </script>

    <script is:inline>
      // Wrap code blocks with title bar and copy button
      (function() {
        document.querySelectorAll('pre.astro-code').forEach(pre => {
          const lang = pre.getAttribute('data-language') || 'text';
          const wrapper = document.createElement('div');
          wrapper.className = 'code-block';

          const title = document.createElement('div');
          title.className = 'code-title';
          title.innerHTML = `<span>${lang}</span>`;

          const copyBtn = document.createElement('button');
          copyBtn.className = 'code-copy';
          copyBtn.textContent = 'Copy';
          copyBtn.addEventListener('click', () => {
            const code = pre.querySelector('code')?.textContent || '';
            navigator.clipboard.writeText(code).then(() => {
              copyBtn.textContent = 'Copied!';
              copyBtn.classList.add('copied');
              setTimeout(() => {
                copyBtn.textContent = 'Copy';
                copyBtn.classList.remove('copied');
              }, 2000);
            });
          });

          title.appendChild(copyBtn);
          pre.parentNode.insertBefore(wrapper, pre);
          wrapper.appendChild(title);
          wrapper.appendChild(pre);
        });

      })();
    </script>
  </body>
</html>
